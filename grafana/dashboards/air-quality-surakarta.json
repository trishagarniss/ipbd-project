{
  "title": "Air Quality Surakarta — ISPU Dashboard",
  "uid": "air-quality-surakarta",
  "tags": ["aqi", "surakarta", "ispu", "air-quality"],
  "schemaVersion": 38,
  "timezone": "Asia/Jakarta",
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "station",
        "type": "query",
        "datasource": { "type": "postgres", "uid": "postgres" },
        "query": "SELECT DISTINCT station_id FROM daily_aqi ORDER BY station_id",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "sort": 1
      },
      {
        "name": "metric",
        "type": "custom",
        "query": "ISPU,PM2.5,PM10,CO,NO2,SO2,O3,Temperature,Humidity,Wind Speed",
        "current": { "text": "ISPU", "value": "ISPU" },
        "includeAll": false,
        "multi": false,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Ringkasan",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Rata-rata ISPU Hari Ini",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["mean"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 },
              { "color": "purple", "value": 300 }
            ]
          },
          "min": 0,
          "max": 500
        },
        "overrides": []
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT round(avg(ispu_avg)::numeric, 1) as value FROM stream_agg WHERE window_start >= now() - interval '24h'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Stasiun ISPU Terburuk",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["max"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT station_id, round(ispu_avg::numeric, 1) as value FROM stream_agg WHERE window_start >= now() - interval '24h' ORDER BY ispu_avg DESC LIMIT 1",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Stasiun Tidak Sehat (ISPU > 100)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT count(DISTINCT station_id) as value FROM stream_agg WHERE ispu_avg > 100 AND window_start >= now() - interval '24h'",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Cakupan Data (24 jam)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 50 },
              { "color": "yellow", "value": 75 },
              { "color": "green", "value": 90 }
            ]
          },
          "min": 0,
          "max": 100
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT round(count(DISTINCT date_trunc('hour', window_start))::numeric / 24 * 100, 0) as value FROM stream_agg WHERE window_start >= now() - interval '24h'",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Time Series",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 5,
      "title": "ISPU 5 Stasiun — 7 Hari Terakhir",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": { "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 200 },
              { "color": "purple", "value": 300 }
            ]
          }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT window_start as time, station_id, ispu_avg FROM stream_agg WHERE window_start >= now() - interval '7d' AND $__timeFilter(window_start) ORDER BY window_start",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "PM2.5 & PM10 — 24 Jam Terakhir",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ugm3",
          "custom": { "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT window_start as time, station_id || ' PM2.5' as metric, pm25_avg FROM stream_agg WHERE window_start >= now() - interval '24h' AND $__timeFilter(window_start) UNION ALL SELECT window_start as time, station_id || ' PM10' as metric, pm10_avg FROM stream_agg WHERE window_start >= now() - interval '24h' AND $__timeFilter(window_start) ORDER BY time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Suhu & Kelembaban — 7 Hari",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "legend": { "calcs": ["mean", "max", "min"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth", "showPoints": "never", "spanNulls": true }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date as time, station_id || ' Suhu' as metric, temperature_avg FROM daily_aqi WHERE date >= now() - interval '7d' AND $__timeFilter(date) UNION ALL SELECT date as time, station_id || ' RH' as metric, humidity_avg FROM daily_aqi WHERE date >= now() - interval '7d' AND $__timeFilter(date) ORDER BY time",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Analisis Harian",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false
    },
    {
      "id": 8,
      "title": "Rata-rata Harian PM2.5 per Stasiun",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "showValue": "auto",
        "legend": { "displayMode": "list", "showLegend": true, "placement": "right" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ugm3",
          "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "bars", "fillOpacity": 80, "gradientMode": "none", "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "mode": "none", "group": "A" }, "thresholdsStyle": { "mode": "off" } }
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT date, station_id, pm25_avg FROM daily_aqi WHERE date >= now() - interval '7d' AND ($__timeFilter(date)) ORDER BY date",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Distribusi Kategori ISPU (Stacked)",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.8,
        "showValue": "auto",
        "legend": { "displayMode": "list", "showLegend": true, "placement": "right" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "axisCenteredZero": false, "axisColorMode": "text", "axisLabel": "", "axisPlacement": "auto", "barAlignment": 0, "drawStyle": "bars", "fillOpacity": 80, "gradientMode": "none", "lineInterpolation": "linear", "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "mode": "normal", "group": "A" }, "thresholdsStyle": { "mode": "off" } },
          "color": { "mode": "palette-classic" }
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT date, aqi_category, count(*) as count FROM daily_aqi WHERE date >= now() - interval '7d' AND ($__timeFilter(date)) GROUP BY date, aqi_category ORDER BY date",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Heatmap ISPU — Jam × Hari (7 hari)",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "calculate": false,
        "calculation": { "xBuckets": { "mode": "size", "scale": { "type": "linear" }, "value": "1h" }, "yBuckets": { "mode": "size", "scale": { "type": "linear" }, "value": "10" } },
        "cellGap": 1,
        "cellValues": {},
        "color": { "exponent": 0.5, "fill": "YlOrRd", "mode": "opacity", "reverse": false, "scale": "linear", "scheme": "Oranges", "steps": 64 },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "mode": "single", "show": true, "showHistogram": false }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT window_start as time, ispu_avg as value FROM stream_agg WHERE window_start >= now() - interval '7d' AND $__timeFilter(window_start) ORDER BY window_start",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Prediksi & Geospasial",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 30 },
      "collapsed": false
    },
    {
      "id": 11,
      "title": "Prediksi vs Aktual ISPU",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "legend": { "calcs": ["mean", "last"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth", "showPoints": "auto", "spanNulls": true }
        }
      },
      "targets": [
        {
          "format": "time_series",
          "rawSql": "SELECT date as time, station_id || ' Aktual' as metric, ispu as value FROM daily_aqi WHERE date >= now() - interval '7d' AND $__timeFilter(date) UNION ALL SELECT window_start as time, station_id || ' Prediksi' as metric, CASE WHEN predicted_label = 'Baik' THEN 25 WHEN predicted_label = 'Sedang' THEN 75 WHEN predicted_label = 'Tidak Sehat' THEN 150 WHEN predicted_label = 'Sangat Tidak Sehat' THEN 250 WHEN predicted_label = 'Berbahaya' THEN 400 ELSE 0 END as value FROM predictions WHERE window_start >= now() - interval '7d' AND $__timeFilter(window_start) ORDER BY time",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "Prediksi Terbaru",
      "type": "table",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 31 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "window_start", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT station_id, window_start, predicted_label, round(confidence::numeric, 2) as confidence, model_version FROM predictions ORDER BY window_start DESC LIMIT 20",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "title": "Peta ISPU Surakarta",
      "type": "geomap",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 31 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "options": {
        "basemap": { "name": "OSM Standard", "type": "osm-standard" },
        "controls": { "mouseWheelZoom": true, "showZoom": true },
        "layers": [
          {
            "type": "markers",
            "name": "Stasiun ISPU",
            "location": { "mode": "coords" },
            "color": { "field": "ispu", "fixed": "dark-green" },
            "size": { "field": "ispu", "fixed": 10, "min": 5, "max": 30 },
            "tooltip": { "mode": "details" },
            "opacity": 0.8
          }
        ],
        "tooltip": { "mode": "details" },
        "view": {
          "lat": -7.565,
          "lon": 110.828,
          "zoom": 12
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        }
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "WITH stations (id, lat, lon) AS (VALUES ('SKA1', -7.5433, 110.8267), ('SKA2', -7.5589, 110.8535), ('SKA3', -7.5725, 110.8028), ('SKA4', -7.5742, 110.8372), ('SKA5', -7.5710, 110.8195)) SELECT s.lat, s.lon, round(da.ispu::numeric, 1) as ispu, da.station_id, da.aqi_category FROM daily_aqi da JOIN stations s ON da.station_id = s.id WHERE da.date = (SELECT max(date) FROM daily_aqi)",
          "refId": "A"
        }
      ]
    }
  ]
}
