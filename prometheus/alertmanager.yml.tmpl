route:
  group_by: ["alertname", "job"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h
  receiver: "telegram"

receivers:
  - name: "telegram"
    webhook_configs:
      - url: "https://api.telegram.org/bot__TELEGRAM_BOT_TOKEN__/sendMessage?chat_id=__TELEGRAM_CHAT_ID__&text={{ .GroupLabels.alertname }}&parse_mode=Markdown"
        send_resolved: true
